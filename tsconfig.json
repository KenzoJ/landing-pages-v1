{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@testing-library/jest-dom": [
        "./src/theme/landing-page-theme/node_modules/@testing-library/jest-dom"
      ],
      "@testing-library/jest-dom/*": [
        "./src/theme/landing-page-theme/node_modules/@testing-library/jest-dom/*"
      ],
      "@testing-library/react": [
        "./src/theme/landing-page-theme/node_modules/@testing-library/react"
      ],
      "@testing-library/react/*": [
        "./src/theme/landing-page-theme/node_modules/@testing-library/react/*"
      ]
    }
  },
  "include": ["vitest.config.ts", "vitest.setup.ts"]
}
