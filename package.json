{
  "name": "landing-page-react-theme",
  "description": "Getting started with CMS React",
  "devDependencies": {
    "@hubspot/prettier-plugin-hubl": "latest",
    "@types/node": "^25.7.0",
    "eslint": "^8.24.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-react": "^7.31.10",
    "jsdom": "^22",
    "prettier": "^2.7.1",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "upload": "hs project upload",
    "start": "cd src/theme/landing-page-theme && npm start",
    "prettier": "prettier . --check",
    "deploy": "hs project upload",
    "test": "vitest",
    "test-verbose": "vitest --reporter verbose",
    "typecheck": "npm run typecheck --prefix src/theme/landing-page-theme",
    "typecheck:modules": "npm run typecheck:modules --prefix src/theme/landing-page-theme",
    "npm-install:all": "npm install && npm install --prefix src/theme/landing-page-theme"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
